# =============================================================================
# Variables de entorno del stack del showroom KT GASTRO.
# Copiar a `.env` y completar antes del primer `docker compose up`:
#   cp .env.example .env
# =============================================================================

# ============================================================
# MySQL
# ============================================================
# Credenciales de la BD, unificadas bajo DB_USERNAME/DB_PASSWORD (mismos nombres
# que el otro proyecto). Alimentan a la vez: MySQL (MYSQL_ROOT_PASSWORD), el
# backend (SPRING_DATASOURCE_*), el healthcheck y el sidecar de backup.
# En un servidor público (Hetzner) es OBLIGATORIO una password fuerte.
# Ej: generar con `openssl rand -base64 24`.
DB_USERNAME=root
DB_PASSWORD=

# ============================================================
# Seguridad / Producción (servidor público con TLS — Coolify)
# ============================================================
# Dominio(s) permitidos para CORS, separados por coma. Poné el dominio real del
# showroom. Vacío = solo same-origin (la app funciona igual porque frontend y
# /api viven en el mismo dominio); NUNCA usar el comodín http://*:* en público.
SHOWROOM_CORS_ALLOWED_ORIGINS=
# Marca la cookie de sesión como Secure (solo viaja por HTTPS). En Coolify
# (siempre TLS) dejar true. Solo poné false si desplegás sin HTTPS.
SERVER_COOKIE_SECURE=true
# Hace que Spring respete X-Forwarded-Proto/Host/For del proxy de Coolify.
# Con TLS delante dejar en `framework`.
SERVER_FORWARD_HEADERS_STRATEGY=framework

# ============================================================
# DUX - Empresa
# Los IDs de empresa/sucursal/depósito son CONFIG FIJA (no secretos) y ya viven
# en application.properties (dux.empresa.id=1068, id-sucursal=3, id-deposito=0).
# NO hace falta setearlos acá ni en Coolify. Solo descomentá la variable
# correspondiente (acá y en docker-compose.yml) si necesitás pisar el valor por
# entorno.
# DUX_EMPRESA_ID=
# DUX_EMPRESA_ID_SUCURSAL=
# DUX_EMPRESA_ID_DEPOSITO=
# DUX_EMPRESA_CATEGORIA_FISCAL_DEFAULT=

# ============================================================
# DUX - Tokens
# Path del HOST con `dux_tokens.json`. Reusable del super-master (misma PC).
# Formato del archivo: { "token": "<token-dux>" }
# ============================================================
DUX_SECRETS_PATH=

# ============================================================
# Imágenes de productos
# Path del HOST con las imágenes {sku}.jpg/png/webp/etc. Se monta read-only.
# El operador la mantiene desde fuera (FTP, sync manual). Después de subir
# imágenes nuevas: POST /api/showroom/admin/imagenes/reindex (sin reiniciar).
# ============================================================
SHOWROOM_IMAGENES_PATH=D:/Doc. Compartidos/IMAGENES

# ============================================================
# Email del picking (opcional — si false, no se manda nada y el pedido se crea igual)
# El destinatario (email-to) se configura desde la pantalla /configuracion
# y vive en la tabla `configuracion`, NO se setea acá.
# ============================================================
SHOWROOM_PICKING_EMAIL_ENABLED=false
SHOWROOM_PICKING_EMAIL_FROM=
# host/port viven en application.properties (smtp.gmail.com:587). Descomentá acá
# y en docker-compose.yml solo si usás otro servidor SMTP.
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
# App password de Gmail (16 caracteres sin espacios) — NO la password normal.
# Generar en: https://myaccount.google.com/apppasswords
SPRING_MAIL_PASSWORD=

# ============================================================
# Pickit externo (programa pickit-y-etiquetas)
# Path del HOST con el .jar, Stock.xlsx, Combos.xlsx y la carpeta de salida.
# Se monta como volumen en /app/pickit del container. Los paths concretos
# (jar, stock, combos, output) se configuran desde /configuracion (BD).
# Si NO usás la integración: dejar esta variable vacía Y comentar el volumen
# correspondiente en docker-compose.yml — sino el `up` falla.
# ============================================================
PICKIT_HOST_PATH=D:/Pickit
